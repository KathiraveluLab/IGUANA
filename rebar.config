{deps, []}.
{erl_opts, [debug_info]}.
{cover_enabled, true}.

{plugins, [pc, rebar3_lint]}.

{port_specs, [
    {"priv/iguana_nif_accelerator.so", ["src/c/iguana_nif_accelerator.c"]},
    {"priv/iguana_nif_accelerator.dll", ["src/c/iguana_nif_accelerator.c"]}
]}.

{port_env, [
    {"(linux|darwin|solaris)", "CFLAGS", "$CFLAGS -O3 -march=native -ffast-math"},
    {"(linux|darwin|solaris)", "LDFLAGS", "$LDFLAGS -lm -lmvec"},
    {"win32", "CFLAGS", "$CFLAGS /O2"}
]}.

{provider_hooks, [
    {pre, [
        {compile, {pc, compile}},
        {clean, {pc, clean}}
    ]}
]}.

{pre_hooks,
  [{"(linux|darwin|solaris)", compile, "make"},
   {"(linux|darwin|solaris)", eunit, "make"},
   {"(linux|darwin|solaris)", ct, "make"}]}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling, underspecs]},
    {get_warnings, true},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [erts, kernel, stdlib]}
]}.

{elvis,
 [
  {config,
   [#{dirs => ["src/erlang"],
      filter => "*.erl",
      rules => [{elvis_style, no_trailing_whitespace},
               {elvis_style, macro_names},
               {elvis_style, macro_module_names},
               {elvis_style, operator_spaces, [{rules, [{allow, '++'}, {allow, '--'}]}]},
               {elvis_style, nesting_level, [{level, 3}]},
               {elvis_style, god_modules, [{limit, 25}]},
               {elvis_style, no_if_expression},
               {elvis_style, line_length, [{limit, 100}, {skip_comments, false}]},
               {elvis_style, no_tabs},
               {elvis_style, no_trailing_whitespace},
               {elvis_style, used_ignored_variable},
               {elvis_style, no_behavior_info},
               {elvis_style, module_naming_convention, [{regex, "^[a-z]([a-z0-9]*_?)*(_SUITE)?$"}, {ignore, []}]},
               {elvis_style, function_naming_convention, [{regex, "^[a-z]([a-z0-9]*_?)*$"}]},
               {elvis_style, state_record_and_type},
               {elvis_style, no_spec_with_records}
              ]
     },
    #{dirs => ["test"],
      filter => "*.erl",
      rules => [{elvis_style, no_trailing_whitespace},
               {elvis_style, line_length, [{limit, 120}]}
              ]
     },
    #{dirs => ["."],
      filter => "rebar.config",
      rules => [{elvis_project, no_deps_master_rebar, [{ignore, []}]}]
     }
   ]
  }
 ]
}.

