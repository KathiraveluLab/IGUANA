{erl_opts, [debug_info]}.

{src_dirs, ["src/erlang"]}.

{deps, [
    %% ErlPort: enables the Erlang Master Controller (iguana_hf_controller) to
    %% spawn and communicate bidirectionally with the Python GPU worker process.
    {erlport, "0.10.1"}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {src_dirs, ["src/erlang"]},
        {deps, [{erlport, "0.10.1"}]}
    ]}
]}.

{eunit_opts, [verbose]}.
{eunit_tests, [iguana_entropy_guard_test]}.
