{deps, [
    {erlport, {git, "https://github.com/jeffutter/erlport.git", {ref, "6f3b67a63230a0bd2cae80a3f41b7e9897cb201b"}}}
]}.
{erl_opts, [debug_info]}.
{cover_enabled, true}.

{plugins, [pc, rebar3_lint]}.

{port_specs, [
    {"priv/iguana_nif_accelerator.so", ["src/c/iguana_nif_accelerator.c"]},
    {"priv/iguana_nif_accelerator.dll", ["src/c/iguana_nif_accelerator.c"]}
]}.

{port_env, [
    {"(linux|darwin|solaris)", "CFLAGS", "$CFLAGS -O3 -march=native -ffast-math"},
    {"(linux|darwin|solaris)", "LDFLAGS", "$LDFLAGS -lm -lmvec"},
    {"win32", "CFLAGS", "$CFLAGS /O2"}
]}.

{provider_hooks, [
    {pre, [
        {compile, {pc, compile}},
        {clean, {pc, clean}}
    ]}
]}.

{pre_hooks,
  [{"(linux|darwin|solaris)", compile, "make"},
   {"(linux|darwin|solaris)", eunit, "make"},
   {"(linux|darwin|solaris)", ct, "make"}]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {get_warnings, true},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [erts, kernel, stdlib, compiler]}
]}.

{elvis,
 [
  {config,
   [#{files => ["src/erlang/*.erl"],
      rules => [{elvis_text_style, no_trailing_whitespace, #{}},
               {elvis_style, macro_naming_convention, #{}},

               {elvis_style, no_deep_nesting, #{level => 3}},
               {elvis_style, no_god_modules, #{limit => 25}},

               {elvis_text_style, max_line_length, #{limit => 100, skip_comments => false}},
               {elvis_text_style, no_tabs, #{}},
               {elvis_style, no_used_ignored_variables, #{}},
               {elvis_style, no_behavior_info, #{}},
               {elvis_style, module_naming_convention, #{regex => "^[a-z]([a-z0-9]*_?)*(_SUITE)?$", ignore => []}},
               {elvis_style, function_naming_convention, #{regex => "^[a-z]([a-z0-9]*_?)*$"}}
              ]
     },
    #{files => ["test/*.erl"],
      rules => [{elvis_text_style, no_trailing_whitespace, #{}},
               {elvis_text_style, max_line_length, #{limit => 120}}
              ]
     },
    #{files => ["rebar.config"],
      rules => [{elvis_project, no_branch_deps, #{ignore => []}}]
     }
   ]
  }
 ]
}.

