{erl_opts, [debug_info]}.

%% All Erlang sources and the OTP app.src descriptor live in src/erlang/.
%% The app.src descriptor lives in src/ (Rebar3 requirement).
{src_dirs, ["src", "src/erlang"]}.

{deps, [
    %% ErlPort: enables the Erlang Master Controller (iguana_hf_controller) to
    %% spawn and communicate bidirectionally with the Python GPU worker process.
    {erlport, "0.10.1"}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {src_dirs, ["src", "src/erlang"]},
        {deps, [{erlport, "0.10.1"}]}
    ]}
]}.

{eunit_opts, [verbose]}.
{eunit_tests, [iguana_entropy_guard_test]}.
